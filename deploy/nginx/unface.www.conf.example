# Canonical domain setup for un-face.com -> www.un-face.com
#
# Suggested target path on server:
#   /etc/nginx/sites-available/unface.conf
#   ln -s /etc/nginx/sites-available/unface.conf /etc/nginx/sites-enabled/unface.conf
#
# Assumptions:
# - Next.js app runs on 127.0.0.1:3000
# - Socket.IO runs on 127.0.0.1:3001
# - HTTPS is terminated by Nginx
# - Certbot certificates already exist or will be issued for both names
# - Basic Auth, if used, should stay on the canonical www host only
#
# Certbot note:
# - Replace YOUR_CERT_NAME with the actual Let's Encrypt live directory name.
# - If you use `certbot --nginx -d un-face.com -d www.un-face.com`, Certbot may
#   add or adjust redirect lines automatically. Keep the same server_name layout.

server {
    listen 80;
    listen [::]:80;
    server_name un-face.com;

    return 301 https://www.un-face.com$request_uri;
}

server {
    listen 80;
    listen [::]:80;
    server_name www.un-face.com;

    return 301 https://www.un-face.com$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name un-face.com;

    ssl_certificate /etc/letsencrypt/live/YOUR_CERT_NAME/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_CERT_NAME/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://www.un-face.com$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.un-face.com;

    ssl_certificate /etc/letsencrypt/live/YOUR_CERT_NAME/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_CERT_NAME/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 10m;

    # Keep Basic Auth on the canonical host only if it is already in use.
    # Uncomment and adjust the htpasswd path if needed.
    # auth_basic "Restricted";
    # auth_basic_user_file /etc/nginx/.htpasswd;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
    }

    location /socket.io/ {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
        proxy_buffering off;
    }
}
