# Suggested target path on server:
#   /etc/turnserver.conf
#
# Replace the placeholder values before starting coturn.
# This draft uses long-term credentials to match TURN_USERNAME / TURN_CREDENTIAL
# from your application environment.

# Network
listening-port=3478
tls-listening-port=5349
listening-ip=0.0.0.0

# Replace with the server's public Static IP.
external-ip=YOUR_LIGHTSAIL_STATIC_IP

# Relay port range example
min-port=49160
max-port=49260
# Open this UDP relay range in Lightsail firewall/security rules.

# Realm must match your real domain later.
realm=turn.your-domain.com
server-name=turn.your-domain.com

# Long-term credential mechanism
lt-cred-mech
fingerprint

# Replace with the same values you plan to use for TURN_USERNAME / TURN_CREDENTIAL
# in .env.production.
user=your-turn-username:your-turn-password

# TLS certificate paths for TURN over TLS on 5349
# Replace these after the domain is connected and Certbot certificates exist.
# If the app uses TURN_URLS, include all of the following in the env:
# - turn:turn.your-domain.com:3478?transport=udp
# - turn:turn.your-domain.com:3478?transport=tcp
# - turns:turn.your-domain.com:5349?transport=tcp
cert=/etc/letsencrypt/live/turn.your-domain.com/fullchain.pem
pkey=/etc/letsencrypt/live/turn.your-domain.com/privkey.pem

# Recommended operational settings
no-cli
no-multicast-peers
stale-nonce=600
log-file=/var/log/turnserver/turnserver.log
simple-log
